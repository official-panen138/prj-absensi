# Telegram bot token from @BotFather
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Chat ID grup tempat QR break dikirim (bot harus di-add ke grup ini)
# Cara dapat: tambah bot ke grup, kirim pesan, buka https://api.telegram.org/bot<TOKEN>/getUpdates
MONITOR_GROUP_CHAT_ID=-1001234567890

# URL Mini App (yang dibuka saat staff klik "Open WMS")
# Untuk dev biasanya: http://localhost:5173/miniapp
# Telegram WebApp butuh HTTPS untuk production
MINIAPP_URL=http://localhost:5173/miniapp

# Backend
PORT=8000
JWT_SECRET=ganti-dengan-random-string-panjang
